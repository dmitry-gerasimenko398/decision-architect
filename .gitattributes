# Canonical LF checkouts keep deterministic generated artifacts byte-reproducible.
* text=auto eol=lf

*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.svg text eol=lf
*.xml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
